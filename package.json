{
  "name": "production-statistics-manager",
  "version": "0.1.0",
  "private": true,
  "main": "src/electron/main.js",
  "description": "Electron + React architecture for Production Statistics Manager",
  "author": "",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "postinstall": "electron-builder install-app-deps",
    "build": "vite build",
    "preview": "vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^6.4.6",
    "@mui/material": "^6.4.6",
    "better-sqlite3": "^11.10.0",
    "exceljs": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "vite": "^6.2.1",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.productionstatisticsmanager.app",
    "productName": "ProductionStatisticsManager",
    "files": [
      "dist/**",
      "src/electron/**",
      "src/preload/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
