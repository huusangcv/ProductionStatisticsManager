{
  "name": "production-statistics-manager",
  "version": "1.0.3",
  "private": true,
  "main": "src/electron/main.js",
  "description": "Electron + React architecture for Production Statistics Manager",
  "author": "",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "postinstall": "electron-builder install-app-deps",
    "build": "vite build",
    "preview": "vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@hookform/resolvers": "^5.4.0",
    "@mui/icons-material": "^6.4.6",
    "@mui/material": "^6.4.6",
    "@mui/x-data-grid": "^7.29.13",
    "@tanstack/react-virtual": "^3.14.4",
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.9.0",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "vite": "^6.2.1",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.productionstatisticsmanager.app",
    "productName": "ProductionStatisticsManager",
    "icon": "resources/icon.png",
    "files": [
      "dist/**",
      "src/electron/**",
      "src/preload/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "huusangcv",
        "repo": "ProductionStatisticsManager",
        "private": false,
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "ProductionStatisticsManager-${version}-Portable.exe"
    }
  }
}
